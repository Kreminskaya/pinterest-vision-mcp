# API key for your vision LLM provider
VISION_API_KEY=your_key_here

# Base URL — change to use any OpenAI-compatible API
# OpenRouter (default):  https://openrouter.ai/api/v1
# OpenAI directly:       https://api.openai.com/v1
# Groq:                  https://api.groq.com/openai/v1
# Mistral:               https://api.mistral.ai/v1
VISION_API_BASE_URL=https://openrouter.ai/api/v1

# Vision model — any model with image support from your provider
# OpenRouter examples:   anthropic/claude-sonnet-4-6   google/gemini-flash-1.5
# OpenAI examples:       gpt-4o   gpt-4o-mini
PINTEREST_VISION_MODEL=anthropic/claude-sonnet-4-6

# Storage paths
PINTEREST_DATA_DIR=./data
CHROMA_PERSIST_DIR=./data/chroma
